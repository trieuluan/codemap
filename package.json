{
  "name": "codemap",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:worker\"",
    "build:shared": "npm --workspace=@codemap/shared run build",
    "dev:api": "npm --workspace=@codemap/api run dev",
    "dev:worker": "npm --workspace=@codemap/api run dev:worker:imports",
    "build:api": "npm run build:shared && npm --workspace=@codemap/api run build:ts",
    "start:api": "npm --workspace=@codemap/api run start",
    "start:worker": "npm --workspace=@codemap/api run worker:imports",
    "test:api": "npm --workspace=@codemap/api run test",
    "dev:web": "npm --workspace=@codemap/web run dev",
    "build:web": "npm run build:shared && npm --workspace=@codemap/web run build",
    "preview:web": "npm --workspace=@codemap/web run start"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "c8": "^10.1.2",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1",
    "fastify-tsconfig": "^3.0.0",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
