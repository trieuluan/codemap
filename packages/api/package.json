{
  "name": "@codemap/api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/app.js",
  "scripts": {
    "test": "npm run build:ts && tsc -p test/tsconfig.json && c8 node --test -r ts-node/register \"test/**/*.ts\"",
    "start": "npm run build:ts && fastify start -l info dist/server.js",
    "build:ts": "tsc -p tsconfig.json",
    "watch:ts": "tsc -w -p tsconfig.json",
    "dev": "tsx watch --inspect=0.0.0.0:9229 --clear-screen=false src/server.ts",
    "dev:workers": "tsx watch --clear-screen=false src/workers/index.ts",
    "dev:worker:imports": "tsx watch --clear-screen=false src/workers/project-import.worker.ts",
    "dev:worker:parses": "tsx watch --clear-screen=false src/workers/project-parse.worker.ts",
    "workers": "tsx src/workers/index.ts",
    "worker:imports": "tsx src/workers/project-import.worker.ts",
    "worker:parses": "tsx src/workers/project-parse.worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.21.1",
    "@bull-board/fastify": "^6.21.1",
    "@fastify/autoload": "^6.3.1",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.0",
    "argon2": "^0.44.0",
    "better-auth": "^1.6.1",
    "bullmq": "^5.73.4",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.4.1",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.8",
    "simple-git": "^3.36.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "c8": "^10.1.2",
    "concurrently": "^9.0.0",
    "ts-node": "^10.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
